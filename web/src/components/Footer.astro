---
const repoUrl = "https://github.com/jmanuelrosa/triage";
const year = new Date().getFullYear();
const buildDate = typeof __BUILD_DATE__ === "string" ? __BUILD_DATE__ : new Date().toISOString().slice(0, 10);
---

<footer class="border-t border-[color:var(--color-line)]">
  <div class="mx-auto max-w-5xl px-6 py-12">
    <div class="flex flex-col items-start justify-between gap-8 sm:flex-row sm:items-center">
      <div>
        <div class="flex items-center gap-2">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-[color:var(--color-accent-3)]"></span>
          <span class="text-sm font-medium text-[color:var(--color-fg)]">Triage</span>
          <span class="text-sm text-[color:var(--color-fg-mute)]">— rule-based URL routing for macOS</span>
        </div>
        <p class="mt-2 max-w-md text-xs leading-relaxed text-[color:var(--color-fg-mute)]">
          v0.1.1 — unsigned beta. Homebrew strips the Gatekeeper
          quarantine automatically; DMG users right-click on first
          launch. macOS 13+, Universal binary (Apple Silicon + Intel).
        </p>
        <address class="mt-3 not-italic text-xs text-[color:var(--color-fg-mute)]">
          Built by
          <a
            rel="author noopener"
            href="https://github.com/jmanuelrosa"
            class="text-[color:var(--color-fg-soft)] underline decoration-[color:var(--color-line)] underline-offset-4 transition hover:text-[color:var(--color-fg)] hover:decoration-[color:var(--color-fg-mute)]"
          >
            jmanuelrosa
          </a>
        </address>
      </div>

      <nav class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
        <a rel="noopener" href={repoUrl} class="text-[color:var(--color-fg-soft)] transition hover:text-[color:var(--color-fg)]">GitHub</a>
        <a rel="noopener" href={`${repoUrl}/blob/main/README.md`} class="text-[color:var(--color-fg-soft)] transition hover:text-[color:var(--color-fg)]">README</a>
        <a rel="noopener" href={`${repoUrl}/blob/main/config.example.yaml`} class="text-[color:var(--color-fg-soft)] transition hover:text-[color:var(--color-fg)]">Example config</a>
        <a rel="noopener" href={`${repoUrl}/issues`} class="text-[color:var(--color-fg-soft)] transition hover:text-[color:var(--color-fg)]">Issues</a>
        <a rel="noopener" href={`${repoUrl}/blob/main/LICENSE`} class="text-[color:var(--color-fg-soft)] transition hover:text-[color:var(--color-fg)]">MIT</a>
      </nav>
    </div>

    <div class="mt-10 flex items-center justify-between text-xs text-[color:var(--color-fg-mute)]">
      <span>© {year} Jose Manuel Rosa Moncayo</span>
      <span class="font-mono">v0.1.1</span>
    </div>
  </div>
</footer>
