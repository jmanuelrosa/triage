---
import { Code } from "astro:components";
import type { ShikiTransformer } from "shiki";

const RULE_KEYS = new Set(["host", "path", "source_app", "cwd", "browser"]);

const triageRuleKeysTransformer: ShikiTransformer = {
  name: "triage-yaml-rule-keys",
  span(node) {
    const child = node.children?.[0];
    if (!child || child.type !== "text") return;
    if (!RULE_KEYS.has(child.value.trim())) return;
    const existing = typeof node.properties.class === "string" ? node.properties.class : "";
    node.properties.class = `${existing} yaml-rule-key`.trim();
  },
};

const yamlSnippet = `rules:
  # gh pr view -w, open https://..., npm scripts —
  # anything in ~/work/* routes to the dev Chrome profile.
  - cwd: "~/work/*"
    browser: work_dev

  # Side projects open in your personal browser instead.
  - cwd: "~/personal/*"
    browser: personal
`;
---

<section
  id="terminal-aware"
  class="relative border-y border-[color:var(--color-line)] bg-[color:var(--color-bg-soft)]/40"
>
  <div class="mx-auto max-w-5xl px-6 py-20 sm:py-24">
    <div class="grid gap-10 lg:grid-cols-[1fr_1.1fr] lg:items-center lg:gap-14">
      <div>
        <div class="flex items-center gap-2 text-xs uppercase tracking-widest">
          <span
            class="inline-block h-1.5 w-1.5 rounded-full"
            style="background: var(--color-accent);"
          ></span>
          <span class="text-[color:var(--color-accent)]">New in v0.1.1</span>
        </div>

        <h2 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
          Open links by the directory you ran them in.
        </h2>

        <p class="mt-4 text-[color:var(--color-fg-soft)]">
          Triage is the only macOS browser router that knows where your terminal was
          when it opened a link.
          <code class="font-mono text-[color:var(--color-fg)]">gh pr view -w</code> from
          <code class="font-mono text-[color:var(--color-fg)]">~/work</code> lands in
          the work Chrome profile;
          <code class="font-mono text-[color:var(--color-fg)]">open https://…</code> from
          <code class="font-mono text-[color:var(--color-fg)]">~/personal</code> opens
          somewhere else entirely.
        </p>

        <p class="mt-3 text-[color:var(--color-fg-soft)]">
          Write a <code class="font-mono text-[color:var(--color-accent)]">cwd</code> rule
          once and forget it. Symlinks are resolved on both sides;
          <code class="font-mono text-[color:var(--color-accent)]">cwd</code>-only rules
          ignore clicks from Slack, Mail, and the rest — those fall through to your other
          rules.
        </p>

        <p class="mt-5 text-sm text-[color:var(--color-fg-mute)]">
          Fires for anything that shells out through
          <code class="font-mono text-[color:var(--color-fg-soft)]">/usr/bin/open</code> —
          <code class="font-mono">open</code>, <code class="font-mono">gh</code>,
          <code class="font-mono">git web--browse</code>, npm scripts, your own aliases.
        </p>
      </div>

      <div>
        <div class="overflow-hidden rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-bg)] shadow-2xl shadow-black/40">
          <div class="flex items-center justify-between border-b border-[color:var(--color-line)] bg-[color:var(--color-bg-soft)] px-4 py-2.5">
            <div class="flex items-center gap-1.5">
              <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
            </div>
            <span class="font-mono text-xs text-[color:var(--color-fg-mute)]">
              ~/.config/triage/config.yaml
            </span>
            <span class="w-12"></span>
          </div>
          <div class="yaml-code">
            <Code
              code={yamlSnippet}
              lang="yaml"
              theme="github-dark-default"
              transformers={[triageRuleKeysTransformer]}
            />
          </div>
        </div>

        <p class="mt-3 text-xs text-[color:var(--color-fg-mute)]">
          First-match-wins, same as every other rule. Drop a
          <code class="font-mono">cwd</code> matcher above your
          <code class="font-mono">host</code> rules to give terminal context priority.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .yaml-code :global(pre.astro-code) {
    margin: 0;
    padding: 1.25rem 1.25rem;
    background: transparent !important;
    font-size: 13px;
    line-height: 1.65;
    overflow-x: auto;
  }
  .yaml-code :global(pre.astro-code code) {
    background: transparent;
  }
</style>
